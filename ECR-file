pipeline {
    agent any

    environment {
        AWS_REGION     = 'ap-south-1'
        AWS_ACCOUNT_ID = '826229823583'
        ECR_REPO_NAME  = 'repo_docker_image'
        ECR_REPO_URI   = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO_NAME}"
        IMAGE_TAG      = "latest" 
        GIT_REPO       = 'https://github.com/Git-ANS/C-project1.git'
    }

    stages {
        stage('Clone Repository') {
            steps {
                // Using the specific repo and branch from your project
                git url: "${GIT_REPO}", branch: 'main'
            }
        }

        stage('Build Artifact') {
            steps {
                echo "Building Java application..."
                // Kept your specific Maven flags for the assignment
                sh 'mvn clean -B -Denforcer.skip=true package'
            }
        }

        stage('ECR Login') {
            steps {
                script {
                    // This command now uses the EC2 IAM Role automatically
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                }
            }
        }

        stage('Build & Push Docker Image') {
            steps {
                script {
                    echo "Building and Pushing Docker image using ECR-file..."
                    // Added -f ECR-file to tell docker which file to use
                    sh "docker build -t ${ECR_REPO_URI}:${IMAGE_TAG} -f ECR-file ."
                    sh "docker push ${ECR_REPO_URI}:${IMAGE_TAG}"
                }
            }
        }
    }

    post {
        success {
            echo "Success! Image pushed to ECR using IAM Role."
        }
        failure {
            echo "Pipeline failed. Check if the IAM Role is attached to the EC2."
        }
    }
}
