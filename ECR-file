pipeline {
    agent any

    environment {
        GIT_REPO = 'https://github.com/Git-ANS/C-project1.git'
        AWS_REGION = 'ap-south-1'
        ECR_REPO_NAME = 'repo_docker_image'
        ECR_REPO_URI = '826229823583.dkr.ecr.ap-south-1.amazonaws.com/repo_docker_image'
        IMAGE_TAG = 'latest'
        AWS_ACCOUNT_ID = '826229823583'
        IMAGE_URI = "${ECR_REPO_URI}:${IMAGE_TAG}"
    }

    stages {   
stage('Configure AWS Credentials') {
    steps {
        sh '''
            mkdir -p /var/lib/jenkins/.aws

            echo "[default]" > /var/lib/jenkins/.aws/credentials
            echo "aws_access_key_id=YOUR_REAL_ACCESS_KEY" >> /var/lib/jenkins/.aws/credentials
            echo "aws_secret_access_key=YOUR_REAL_SECRET_KEY" >> /var/lib/jenkins/.aws/credentials

            cat /var/lib/jenkins/.aws/credentials
        '''
    }
}

       
        stage('Clone Repository') {
            steps {
                git url: "${GIT_REPO}", branch: 'main'
            }
        }

        stage('Build Application') {
            steps {
                sh '''
                    echo "Building Java application..."
                    mvn clean -B -Denforcer.skip=true package
                '''
            }
        }

        stage('Login to ECR') {
            steps {
                sh '''
                    aws ecr get-login-password --region $AWS_REGION \
                    | docker login --username AWS --password-stdin $AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    echo "Building Docker image..."
                    docker build -t ${IMAGE_URI} .
                '''
            }
        }

        stage('Push Docker Image to ECR') {
            steps {
                sh '''
                    echo "Pushing Docker image to ECR..."
                    docker push ${IMAGE_URI}
                '''
            }
        }

    }  

    post {
        success {
            echo "Docker image pushed to ECR successfully."
        }
        failure {
            echo "Pipeline failed."
        }
    }
}
